[Unit]
Description=ComCoach FastAPI Backend
After=network.target

[Service]
User=ec2-user
Group=ec2-user
WorkingDirectory=/opt/comcoach/ComCoachAI_V3
EnvironmentFile=/opt/comcoach/ComCoachAI_V3/.env
ExecStart=/opt/comcoach/ComCoachAI_V3/venv/bin/uvicorn backend.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
